                        }, 
                        {
                         "height":4,
                         "id":194,
                         "name":"dialog_home_sweet_home",
                         "opacity":1,
                         "properties":[
                                {
                                 "name":"character",
                                 "propertytype":"CharacterComponent",
                                 "type":"class",
                                 "value":
                                    {
                                     "fightable":true
                                    }
                                }, 
                                {
                                 "name":"dialog",
                                 "propertytype":"DIALOG_COMPONENT",
                                 "type":"class",
                                 "value":
                                    {
                                     "dialog_node":[
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"Hold up, son! One of these bastards entered our house! Remember what I taught you: if you just flail that weapon around, you'll be meat in seconds."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "nextnodeId":11
                                                    },
                                                 "text":"I know how to fight. Point me to the enemy."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "nextnodeId":3
                                                    },
                                                 "text":"I'm listening. What's the strategy?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"Pay attention. Combat is about managing your energy. Every time you swing, it costs you Action Points\u2014AP. Keep an eye on them. A Light Attack is quick and costs 1 AP. A Heavy Attack costs 2 AP and hits harder, but if you drain yourself, you'll be left wide open."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "nextnodeId":5
                                                    },
                                                 "text":"What happens if I completely run out of AP?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"Then you catch your breath. If you're tapped out, take a tactical Rest. It restores 2 AP. Sometimes standing your ground and recovering is the only way to survive the next round."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "nextnodeId":7
                                                    },
                                                 "text":"What about my special gear and techniques?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"You can use Ultimate Attacks or patch yourself up with a Heal. They still cost AP, but you can't spam them. You only have a limited number of uses per fight. Burn through them on weaklings, and you'll have nothing left when the real monsters show up."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "nextnodeId":9
                                                    },
                                                 "text":"Got it. Anything else?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"One last thing. With experience, you'll learn new abilities and become stronger. It only gets better from there."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "nextnodeId":11
                                                    },
                                                 "text":"I'm ready."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"Now grab the kitchen knife and kill that m***********!"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
