                        }, 
                        {
                         "gid":1121,
                         "height":16,
                         "id":199,
                         "name":"npc_dad_dead",
                         "opacity":1,
                         "properties":[
                                {
                                 "name":"character",
                                 "propertytype":"CharacterComponent",
                                 "type":"class",
                                 "value":
                                    {
                                     "fightable":false,
                                     "inventory":
                                        {
                                         "inventoryWorldId":130
                                        },
                                     "stats":
                                        {
                                         "currentHealth":100,
                                         "maxHealth":100
                                        }
                                    }
                                }, 
                                {
                                 "name":"dialog",
                                 "propertytype":"DIALOG_COMPONENT",
                                 "type":"class",
                                 "value":
                                    {
                                     "dialog_node":[
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"Son, one of those b****** got me. It's too late for me. Find your mother and your brother. Take them to the city. They'll be safe behind the walls."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":3
                                                    },
                                                 "text":"Where are they?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":3
                                                    },
                                                 "text":"No! I'm not leaving you here!"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"They ran toward the barn. I heard them screaming before those things dragged me down. Take the axe by the woodpile and get them out."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":5
                                                    },
                                                 "text":"There must be something I can do for you."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"Light the campfire. Give me a little warmth before I go. I'll keep those beasts away from the car for as long as I can. Then you get your ass out of here."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":8
                                                    },
                                                 "text":"All right. I'll light it."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":-1
                                                    },
                                                 "text":"I got no time for this campfire nonesense."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"Sit down for a moment. The cold will kill you just as quickly as the infected."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":11
                                                    },
                                                 "text":"I don't have time to rest. My family needs me."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":13
                                                    },
                                                 "text":"What makes this fire so important?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"Then listen while you work. You'll find more fires out there. Never pass one without lighting it."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":15
                                                    },
                                                 "text":"I'll remember that."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"This fire is an anchor. Out there, people die, weapons break, and every mistake leaves a scar. It's easy to lose everything."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":15
                                                    },
                                                 "text":"What happens if the darkness takes me?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"The fire remembers. Rest beside its flames, and your journey is carved into the ash. If the darkness takes you, this is where your story begins again."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":18
                                                    },
                                                 "text":"So if I die, I return to this fire?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":20
                                                    },
                                                 "text":"Are there other fires like this?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"Aye. Death will take its price, but it won't be the end - not while a flame still remembers your name."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":22
                                                    },
                                                 "text":"Then I'll keep the flame alive."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"They're scattered across the countryside. Some still burn. Others are waiting for someone brave - or foolish - enough to relight them."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":22
                                                    },
                                                 "text":"I'll light every one I find."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"Now go. Save your mother. Protect your brother. And whatever you hear behind you... don't turn around."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":24
                                                    },
                                                 "text":"I'll come back for you. I promise."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":199
                                                    },
                                                 "text":"No, son. Go get the axe."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":-1
                                                    },
                                                 "text":"Goodbye, Dad."
                                                }
                                            }]
                                    }
                                }, 
