                                                {
                                                 "isNodeData":
                                                    {
                                                     "speaker":168
                                                    },
                                                 "text":"This son of a b****! They must have entered somewhere through the fences. Go help me find your mum and your brother."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
