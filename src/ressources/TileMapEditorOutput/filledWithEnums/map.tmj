                        }, 
                        {
                         "gid":617,
                         "height":16,
                         "id":198,
                         "name":"npc_brother",
                         "opacity":1,
                         "properties":[
                                {
                                 "name":"animation",
                                 "propertytype":"ANIMATION_COMPONENT",
                                 "type":"class",
                                 "value":
                                    {
                                     "sequences":[
                                            {
                                             "propertytype":"AnimationSequence",
                                             "type":"class",
                                             "value":
                                                {
                                                 "sequence":[
                                                        {
                                                         "propertytype":"Animation",
                                                         "type":"class",
                                                         "value":
                                                            {
                                                             "entitySpriteId":143
                                                            }
                                                        }],
                                                 "state":5
                                                }
                                            }]
                                    }
                                }, 
                                {
                                 "name":"character",
                                 "propertytype":"CharacterComponent",
                                 "type":"class",
                                 "value":
                                    {
                                     "fightable":false,
                                     "inventory":
                                        {
                                         "inventoryWorldId":130
                                        },
                                     "stats":
                                        {
                                         "currentHealth":60,
                                         "dexterity":3,
                                         "faith":5,
                                         "maxHealth":60,
                                         "strength":1
                                        }
                                    }
                                }, 
                                {
                                 "name":"dialog",
                                 "propertytype":"DIALOG_COMPONENT",
                                 "type":"class",
                                 "value":
                                    {
                                     "dialog_node":[
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"Thank you, brother. I thought I was going to die in that barn. If you hadn't come when you did, those things would have torn me apart."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":2
                                                    },
                                                 "text":"Where's Mum? Dad said she was with you. What happened?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"Mum left for Gas Town before the roads were blocked. She thought we'd be safe behind the city walls. We were supposed to follow, but the car ran out of fuel. Then the infected came, and I got trapped in the barn."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":4
                                                    },
                                                 "text":"Dad didn't make it. He died protecting the house and the car."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"No... Dad can't be gone. I thought we'd have more time."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":7
                                                    },
                                                 "text":"I'm sorry. But Mum is still out there. I have to find her."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":7
                                                    },
                                                 "text":"We have to find Mum. What's the plan?"
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"We need to go to the lighthouse on the coast. We stored emergency fuel there for the generator. With that fuel, we can start the car and reach Gas Town."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":1,
                                                     "get_item_id":230,
                                                     "nextnodeId":9
                                                    },
                                                 "text":"Then give me the lighthouse key. I'll bring back the fuel."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"Take it. But listen... I could come with you. My leg is hurt, though, and we both know we've never worked well together. I might help you survive, or I might slow you down."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":12
                                                    },
                                                 "text":"We're not close, but you're still my brother. Dad died saving both of us. Come with me."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":14
                                                    },
                                                 "text":"You're injured. Stay here and get the car ready. I'll move faster alone."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"You always did know how to turn an order into a speech. Fine. You convinced me. I'm coming with you."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":3,
                                                     "nextnodeId":-1
                                                    },
                                                 "text":"Then grab your things. We leave together."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":0,
                                                 "isNodeData":
                                                    {
                                                     "speaker":198
                                                    },
                                                 "text":"Maybe you're right. I'll barricade the barn and prepare the car. Just make sure you come back with that fuel."
                                                }
                                            }, 
                                            {
                                             "propertytype":"DIALOG",
                                             "type":"class",
                                             "value":
                                                {
                                                 "dialogType":1,
                                                 "isChoiceData":
                                                    {
                                                     "action":0,
                                                     "nextnodeId":-1
                                                    },
                                                 "text":"Keep the doors locked. I'll be back."
                                                }
                                            }]
                                    }
                                }, 
